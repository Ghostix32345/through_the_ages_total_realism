types MarketOverview {
	type market_overview_goods = vbox {
		using = layoutpolicy_expanding

		filtered_sorted_list = {
			datacontext = "[SelectedMarketLateralView.GetGoodsMarketEntriesSortSearch]"

			blockoverride "sort_buttons_filtered_list" {
				sort_by_key_button = {
					name = "name"
					layoutpolicy_vertical = expanding
					size = { 35 -1 }
				}

				sort_by_key_button = {
					name = "stockpile"
					layoutpolicy_vertical = expanding
					size = { 35 -1 }
				}

				sort_by_key_button = {
					name = "goods_local_balance"
					layoutpolicy_vertical = expanding
					size = { 55 -1 }
				}

				sort_by_key_button = {
					name = "goods_imports"
					layoutpolicy_vertical = expanding
					size = { 70 -1 }
				}

				sort_by_key_button = {
					name = "goods_exports"
					layoutpolicy_vertical = expanding
					size = { 70 -1 }
				}

				sort_by_key_button = {
					name = "goods_balance"
					layoutpolicy_vertical = expanding
					size = { 75 -1 }
				}

				sort_by_key_button = {
					name = "market_price"
					layoutpolicy_vertical = expanding
					size = { 45 -1 }
				}

				sort_by_key_button = {
					name = "market_price_diff"
					using = layoutpolicy_expanding
				}
			}

			blockoverride "scroll_list_layout" {
				fixedgridbox = {
					position = {0 80%}
					addcolumn = 100%
					addrow = 55
					datamodel = "[SelectedMarketLateralView.GetGoodsMarketEntries]"

					item = {
						widget = {
							size = { 100% 35 }
							scroll_card = {
								using = bg_paper_card
								parentanchor = top
								size = { 99% 50 }
								using = goods_entry
							}
						}
					}
				}
			}
		}
	}
}

types MarketsInRangeOverview {
	type markets_in_range_overview_goods = vbox {
		using = layoutpolicy_expanding

		filtered_sorted_list = {
			datacontext = "[SelectedMarketLateralView.GetInRangeGoodsEntriesSortSearch]"

			blockoverride "sort_buttons_filtered_list" {
				sort_by_key_button = {
					name = "name"
					layoutpolicy_vertical = expanding
					size = { 25 -1 }
				}

				sort_by_key_button = {
					name = "in_range_produced"
					layoutpolicy_vertical = expanding
					size = { 55 -1 }
				}
				sort_by_key_button = {
					name = "in_range_locally_demanded"
					layoutpolicy_vertical = expanding
					size = { 55 -1 }
				}

				sort_by_key_button = {
					name = "in_range_local_balance"
					layoutpolicy_vertical = expanding
					size = { 55 -1 }
				}

				sort_by_key_button = {
					name = "in_range_imports"
					layoutpolicy_vertical = expanding
					size = { 70 -1 }
				}

				sort_by_key_button = {
					name = "in_range_exports"
					layoutpolicy_vertical = expanding
					size = { 70 -1 }
				}

				sort_by_key_button = {
					name = "in_range_balance"
					layoutpolicy_vertical = expanding
					size = { 75 -1 }
				}
			}

			blockoverride "scroll_list_layout" {
				fixedgridbox = {
					position = {0 80%}
					addcolumn = 100%
					addrow = 40
					datamodel = "[SelectedMarketLateralView.GetInRangeGoodsEntries]"

					item = {
						widget = {
							size = { 100% 35 }
							scroll_card = {
								using = bg_paper_card
								parentanchor = center
								size = { 99% 35 }
								using = goods_in_range_entry
							}
						}
					}
				}
			}
		}
	}
}